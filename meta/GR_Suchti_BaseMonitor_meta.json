{
  "displayName": "Base Monitor",
  "devMessage": {
    "en": "Please update to v0.1.1 if base data is not showing correctly after the latest game update.\n\nNote: This mod will likely break after every game update. A compatibility fix will be provided as soon as possible.",
    "de": "Bitte auf v0.1.1 aktualisieren, wenn die Basisdaten nach dem letzten Game-Update nicht korrekt angezeigt werden.\n\nHinweis: Diese Mod wird wahrscheinlich nach jedem Game-Update nicht mehr funktionieren. Ein Kompatibilitäts-Fix wird so schnell wie möglich bereitgestellt.",
    "fr": "Merci de mettre à jour vers v0.1.1 si les données de base ne s'affichent pas correctement après la dernière mise à jour du jeu.\n\nNote : Ce mod sera probablement cassé après chaque mise à jour du jeu. Un correctif de compatibilité sera fourni dès que possible.",
    "pl": "Zaktualizuj do v0.1.1, jeśli dane bazy nie wyświetlają się poprawnie po najnowszej aktualizacji gry.\n\nUwaga: Ten mod prawdopodobnie przestanie działać po każdej aktualizacji gry. Poprawka kompatybilności zostanie udostępniona jak najszybciej."
  },
  "uiText": {
    "title": { "en": "Base Monitor", "de": "Base Monitor", "fr": "Base Monitor", "pl": "Base Monitor" },
    "base": { "en": "Base", "de": "Basis", "fr": "Base", "pl": "Baza" },
    "needs": { "en": "Needs", "de": "Bedarf", "fr": "Besoins", "pl": "Potrzeby" },
    "dept": { "en": "Dept", "de": "Abt.", "fr": "Serv.", "pl": "Dz." },
    "cars": { "en": "Cars", "de": "Fzg.", "fr": "Veh.", "pl": "Poj." },
    "employees": { "en": "Employees", "de": "Mitarb.", "fr": "Employes", "pl": "Prac." },
    "Hunger": { "en": "Hunger", "de": "Hunger", "fr": "Faim", "pl": "Glod" },
    "Toilet": { "en": "Toilet", "de": "Toilette", "fr": "Toilette", "pl": "Toaleta" },
    "Shower": { "en": "Shower", "de": "Dusche", "fr": "Douche", "pl": "Prysznic" },
    "Energy": { "en": "Energy", "de": "Energie", "fr": "Energie", "pl": "Energia" },
    "Satisf": { "en": "Satisf", "de": "Zufr.", "fr": "Satisf.", "pl": "Zadow." },
    "waiting": { "en": "Waiting for save game", "de": "Warte auf Spielstand", "fr": "En attente de la sauvegarde", "pl": "Oczekiwanie na zapis gry" },
    "no_bases": { "en": "No bases found", "de": "Keine Basen gefunden", "fr": "Aucune base trouvee", "pl": "Nie znaleziono baz" },
    "unavailable": { "en": "Base data unavailable", "de": "Basisdaten nicht verfügbar", "fr": "Donnees de base indisponibles", "pl": "Dane bazy niedostepne" },
    "department_police": { "en": "POL", "de": "POL", "fr": "POL", "pl": "POL" },
    "department_fire": { "en": "FIRE", "de": "FW", "fr": "POM", "pl": "STR" },
    "department_rescue": { "en": "EMS", "de": "RD", "fr": "SAMU", "pl": "RM" },
    "department_swat": { "en": "SWAT", "de": "SEK", "fr": "RAID", "pl": "AT" }
  },
  "sections": [
    { "id": "General", "label": { "en": "General", "de": "Allgemein" }, "order": 0 },
    { "id": "UI", "label": { "en": "UI", "de": "UI" }, "order": 1 },
    { "id": "Performance", "label": { "en": "Performance", "de": "Performance" }, "order": 2 }
  ],
  "actions": [
    {
      "id": "reset_position",
      "section": "UI",
      "label": { "en": "Reset Position", "de": "Reset Position" },
      "type": "resetToDefault",
      "targets": [
        "ButtonAnchor",
        "ButtonOffsetX",
        "ButtonOffsetY",
        "ButtonSize",
        "WindowAnchor",
        "WindowOffsetX",
        "WindowOffsetY",
        "WindowWidth",
        "WindowHeight"
      ]
    }
  ],
  "settings": {
    "Enabled": {
      "control": "toggle",
      "label": { "en": "Enabled", "de": "Aktiviert" },
      "description": { "en": "Enable the Base Monitor.", "de": "Aktiviert den Base Monitor." }
    },
    "ShowOverlayButton": {
      "control": "toggle",
      "label": { "en": "Show Button", "de": "Button anzeigen" },
      "description": { "en": "Show the small fixed overlay button.", "de": "Zeigt den kleinen festen Overlay-Button." }
    },
    "Hotkey": {
      "control": "hotkey",
      "label": { "en": "Open / Close Hotkey", "de": "Öffnen / Schließen Taste" },
      "description": { "en": "Key to toggle the Base Monitor.", "de": "Taste zum Öffnen oder Schließen des Base Monitors." }
    },
    "ButtonAnchor": {
      "control": "choice",
      "label": { "en": "Button Corner", "de": "Button-Ecke" },
      "description": { "en": "Screen corner used for the overlay button.", "de": "Bildschirmecke für den Overlay-Button." },
      "options": [
        { "value": "TopLeft", "label": { "en": "Top Left", "de": "Oben links" } },
        { "value": "TopRight", "label": { "en": "Top Right", "de": "Oben rechts" } },
        { "value": "BottomLeft", "label": { "en": "Bottom Left", "de": "Unten links" } },
        { "value": "BottomRight", "label": { "en": "Bottom Right", "de": "Unten rechts" } }
      ]
    },
    "ButtonOffsetX": {
      "control": "slider",
      "label": { "en": "Button Offset X", "de": "Button Abstand X" },
      "description": { "en": "Horizontal distance from the selected button corner.", "de": "Horizontaler Abstand von der gewählten Button-Ecke." },
      "min": 0,
      "max": 1000,
      "step": 1
    },
    "ButtonOffsetY": {
      "control": "slider",
      "label": { "en": "Button Offset Y", "de": "Button Abstand Y" },
      "description": { "en": "Vertical distance from the selected button corner.", "de": "Vertikaler Abstand von der gewählten Button-Ecke." },
      "min": 0,
      "max": 500,
      "step": 1
    },
    "ButtonSize": {
      "control": "slider",
      "label": { "en": "Button Size", "de": "Button-Größe" },
      "description": { "en": "Overlay button size in pixels.", "de": "Größe des Overlay-Buttons in Pixeln." },
      "min": 32,
      "max": 96,
      "step": 1
    },
    "WindowAnchor": {
      "control": "choice",
      "label": { "en": "Window Corner", "de": "Fenster-Ecke" },
      "description": { "en": "Screen corner used for the initial monitor window position.", "de": "Bildschirmecke für die anfängliche Fensterposition." },
      "options": [
        { "value": "TopLeft", "label": { "en": "Top Left", "de": "Oben links" } },
        { "value": "TopRight", "label": { "en": "Top Right", "de": "Oben rechts" } },
        { "value": "BottomLeft", "label": { "en": "Bottom Left", "de": "Unten links" } },
        { "value": "BottomRight", "label": { "en": "Bottom Right", "de": "Unten rechts" } }
      ]
    },
    "WindowOffsetX": {
      "control": "slider",
      "label": { "en": "Window Offset X", "de": "Fenster Abstand X" },
      "description": { "en": "Initial horizontal distance from the selected window corner.", "de": "Anfänglicher horizontaler Abstand von der gewählten Fenster-Ecke." },
      "min": 0,
      "max": 800,
      "step": 1
    },
    "WindowOffsetY": {
      "control": "slider",
      "label": { "en": "Window Offset Y", "de": "Fenster Abstand Y" },
      "description": { "en": "Initial vertical distance from the selected window corner.", "de": "Anfänglicher vertikaler Abstand von der gewählten Fenster-Ecke." },
      "min": 0,
      "max": 600,
      "step": 1
    },
    "WindowOpacity": {
      "control": "slider",
      "label": { "en": "Window Opacity", "de": "Fenster-Transparenz" },
      "description": { "en": "Monitor window opacity between 0.1 and 1.0.", "de": "Fenstertransparenz zwischen 0.1 und 1.0." },
      "min": 0.1,
      "max": 1.0,
      "step": 0.01
    },
    "WindowWidth": {
      "control": "slider",
      "label": { "en": "Window Width", "de": "Fensterbreite" },
      "description": { "en": "Monitor window width.", "de": "Breite des Monitor-Fensters." },
      "min": 260,
      "max": 640,
      "step": 1
    },
    "WindowHeight": {
      "control": "slider",
      "label": { "en": "Window Height", "de": "Fensterhöhe" },
      "description": { "en": "Monitor window height.", "de": "Höhe des Monitor-Fensters." },
      "min": 300,
      "max": 720,
      "step": 1
    },
    "RefreshIntervalSeconds": {
      "control": "slider",
      "label": { "en": "Refresh Interval", "de": "Aktualisierung" },
      "description": { "en": "Seconds between monitor data refreshes while open.", "de": "Sekunden zwischen Aktualisierungen, solange das Fenster offen ist." },
      "min": 0.25,
      "max": 5.0,
      "step": 0.25
    }
  }
}
